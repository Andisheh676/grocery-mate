#!/bin/bash
# Pre-commit hook to detect secrets before committing

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "Running secret detection..."

# Check if gitleaks is installed
if command -v gitleaks &> /dev/null; then
    # Run gitleaks on staged files
    gitleaks protect --staged --verbose
    GITLEAKS_EXIT=$?
    
    if [ $GITLEAKS_EXIT -ne 0 ]; then
        echo -e "${RED}❌ Secret detected! Commit blocked.${NC}"
        echo -e "${YELLOW}Please remove the secret and try again.${NC}"
        exit 1
    fi
else
    # Fallback: Simple regex checks if gitleaks is not installed
    echo -e "${YELLOW}⚠️  Gitleaks not installed. Running basic secret detection...${NC}"
    
    # Get list of staged files
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
    
    # Check for common secret patterns
    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            # Check for SSH keys
            if grep -q "BEGIN.*PRIVATE KEY" "$file" 2>/dev/null; then
                echo -e "${RED}❌ Private key detected in $file${NC}"
                exit 1
            fi
            
            # Check for AWS keys
            if grep -qE "AKIA[0-9A-Z]{16}" "$file" 2>/dev/null; then
                echo -e "${RED}❌ AWS access key detected in $file${NC}"
                exit 1
            fi
        fi
    done
fi

echo -e "${GREEN}✅ No secrets detected${NC}"
exit 0
